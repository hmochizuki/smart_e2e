{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo.typecheck",
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
